// Timeline Management - PostgreSQL Schema
// Workforce scheduling platform

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  admin
  manager
  employee
}

enum ScheduleStatus {
  draft
  published
}

enum Recurrence {
  weekly
  biweekly
  custom
}

enum SwapRequestStatus {
  pending_target
  pending_manager
  approved
  rejected
  expired
  cancelled
}

// ─── Models ──────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users      User[]
  employees  Employee[]
  schedules  Schedule[]

  @@map("organizations")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  orgId        String       @db.Uuid
  email        String       @unique
  passwordHash String
  role         UserRole     @default(employee)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  organization  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee      Employee?
  resolvedSwaps SwapRequest[]

  @@index([orgId])
  @@map("users")
}

model Employee {
  id        String    @id @default(uuid()) @db.Uuid
  orgId     String    @db.Uuid
  userId    String?   @unique @db.Uuid
  firstName String
  lastName  String
  email     String
  phone     String?
  position  String?
  hiredAt   DateTime?
  createdAt DateTime  @default(now())

  organization            Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                    User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  shifts                  Shift[]
  availabilities          Availability[]
  requestingSwapRequests  SwapRequest[]  @relation("RequestingEmployee")
  targetSwapRequests      SwapRequest[]  @relation("TargetEmployee")

  @@index([orgId])
  @@index([email])
  @@map("employees")
}

model Schedule {
  id        String         @id @default(uuid()) @db.Uuid
  orgId     String         @db.Uuid
  name      String
  weekStart DateTime
  status    ScheduleStatus @default(draft)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  organization  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shifts        Shift[]
  swapRequests  SwapRequest[]

  @@index([orgId])
  @@index([weekStart])
  @@map("schedules")
}

model Shift {
  id         String   @id @default(uuid()) @db.Uuid
  scheduleId String   @db.Uuid
  employeeId String   @db.Uuid
  startTime  DateTime
  endTime    DateTime
  role       String?
  notes      String?
  createdAt  DateTime @default(now())

  schedule               Schedule      @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  employee               Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requestingSwapRequests SwapRequest[] @relation("RequestingShift")
  targetSwapRequests     SwapRequest[] @relation("TargetShift")

  @@index([scheduleId])
  @@index([employeeId])
  @@index([startTime, endTime])
  @@map("shifts")
}

model Availability {
  id         String     @id @default(uuid()) @db.Uuid
  employeeId String     @db.Uuid
  dayOfWeek  Int        // 0=Sun, 6=Sat
  startTime  String     // HH:MM format
  endTime    String     // HH:MM format
  recurrence Recurrence @default(weekly)
  createdAt  DateTime   @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("availabilities")
}

model SwapRequest {
  id                   String            @id @default(uuid()) @db.Uuid
  scheduleId           String            @db.Uuid
  requestingEmployeeId String            @db.Uuid
  requestingShiftId    String            @db.Uuid
  targetEmployeeId     String?           @db.Uuid
  targetShiftId        String?           @db.Uuid
  status               SwapRequestStatus @default(pending_target)
  resolvedAt           DateTime?
  resolvedBy           String?           @db.Uuid
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  schedule           Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  requestingEmployee Employee @relation("RequestingEmployee", fields: [requestingEmployeeId], references: [id], onDelete: Cascade)
  requestingShift    Shift    @relation("RequestingShift", fields: [requestingShiftId], references: [id], onDelete: Cascade)
  targetEmployee     Employee? @relation("TargetEmployee", fields: [targetEmployeeId], references: [id], onDelete: SetNull)
  targetShift        Shift?    @relation("TargetShift", fields: [targetShiftId], references: [id], onDelete: SetNull)
  resolver           User?     @relation(fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([status, scheduleId])
  @@index([requestingEmployeeId])
  @@index([targetEmployeeId])
  @@map("swap_requests")
}
