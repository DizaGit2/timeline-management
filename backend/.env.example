# Database
DATABASE_URL="postgresql://user:password@localhost:5432/timeline_management?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-a-different-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Sentry Error Tracking (optional)
# Obtain your DSN from https://sentry.io after creating a project
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
